SEPOLIA_RPC_URL=
DEPLOYER_PRIVATE_KEY=

# ─────────────────────────────────────────────────────────────
# Algorand Testnet Adapter Integration
# ─────────────────────────────────────────────────────────────

# Set to "true" to enable the real Algorand adapter client.
# When false or absent, AlgorandAdapterStub is used (safe no-op).
ALGORAND_ADAPTER_ENABLED=false

# On-chain application ID of the deployed SolventRegistry contract.
# Required when ALGORAND_ADAPTER_ENABLED=true.
ALGORAND_APP_ID=

# Algorand Algod node configuration.
# Defaults to the public AlgoNode testnet endpoint (no account required).
ALGORAND_ALGOD_URL=https://testnet-api.algonode.cloud
ALGORAND_ALGOD_TOKEN=
ALGORAND_ALGOD_PORT=443

# Network identifier used for logging / display purposes.
ALGORAND_NETWORK=testnet

# 25-word Algorand mnemonic for the account that signs submit_epoch transactions.
# Required when ALGORAND_ADAPTER_ENABLED=true and you intend to submit epochs.
# For read-only usage (getLatestState, getEpochRecord, etc.) this can be left blank.
# IMPORTANT: Never commit a real mnemonic to version control.
ALGO_MNEMONIC=

# Override sender address derived from ALGO_MNEMONIC (optional).
# Leave blank to derive automatically from the mnemonic.
ALGORAND_SENDER_ADDRESS=

# Rate limiting
# Global rate limit (applies to all endpoints)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
# Strict rate limit for /api/epoch/verify-stored (on-chain RPC call)
VERIFY_STORED_RATE_LIMIT_WINDOW_MS=900000
VERIFY_STORED_RATE_LIMIT_MAX=10
